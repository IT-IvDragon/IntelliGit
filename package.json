{
    "name": "intelligit",
    "displayName": "IntelliGit",
    "description": "IntelliJ-style Git UI for VS Code with commit graph, commit details, shelf workflow, and file change explorer.",
    "version": "0.6.2",
    "publisher": "MaheshKok",
    "icon": "media/intelligit-icon.png",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/MaheshKok/IntelliGit"
    },
    "engines": {
        "vscode": "^1.96.0"
    },
    "categories": [
        "SCM Providers"
    ],
    "keywords": [
        "git",
        "intellij",
        "intellij git",
        "pycharm",
        "pycharm git",
        "intelligent git",
        "intelligit",
        "git client",
        "git gui",
        "commit graph",
        "git graph",
        "branch manager",
        "shelf",
        "stash",
        "source control",
        "log",
        "graph",
        "scm"
    ],
    "activationEvents": [
        "workspaceContains:.git",
        "onView:intelligit.commitGraph"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "intelligit",
                    "title": "%views.activitybar.title%",
                    "icon": "media/intelligit.svg"
                }
            ],
            "panel": [
                {
                    "id": "intelligitPanel",
                    "title": "%views.panel.title%",
                    "icon": "media/intelligit.svg"
                }
            ]
        },
        "views": {
            "intelligit": [
                {
                    "id": "intelligit.commitPanel",
                    "name": "%views.commitPanel.name%",
                    "type": "webview"
                },
                {
                    "id": "intelligit.mergeConflicts",
                    "name": "%views.mergeConflicts.name%",
                    "when": "intelligit.hasMergeConflicts"
                },
                {
                    "id": "intelligit.fileCountBadge",
                    "name": "%views.changes.name%",
                    "visibility": "hidden"
                }
            ],
            "intelligitPanel": [
                {
                    "id": "intelligit.commitGraph",
                    "name": "",
                    "type": "webview"
                }
            ]
        },
        "commands": [
            {
                "command": "intelligit.showGitLog",
                "title": "%command.showGitLog.title%",
                "category": "IntelliGit",
                "icon": "$(git-commit)"
            },
            {
                "command": "intelligit.refresh",
                "title": "%command.refresh.title%",
                "category": "IntelliGit",
                "icon": "$(refresh)"
            },
            {
                "command": "intelligit.filterByBranch",
                "title": "%command.filterByBranch.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.checkout",
                "title": "%command.checkout.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.newBranchFrom",
                "title": "%command.newBranchFrom.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.checkoutAndRebase",
                "title": "%command.checkoutAndRebase.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.rebaseCurrentOnto",
                "title": "%command.rebaseCurrentOnto.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.mergeIntoCurrent",
                "title": "%command.mergeIntoCurrent.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.updateBranch",
                "title": "%command.updateBranch.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.pushBranch",
                "title": "%command.pushBranch.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.renameBranch",
                "title": "%command.renameBranch.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.deleteBranch",
                "title": "%command.deleteBranch.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.fileRollback",
                "title": "%command.fileRollback.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.fileJumpToSource",
                "title": "%command.fileJumpToSource.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.fileDelete",
                "title": "%command.fileDelete.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.fileShelve",
                "title": "%command.fileShelve.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.fileShowHistory",
                "title": "%command.fileShowHistory.title%",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.compareWithRevision",
                "title": "%command.compareWithRevision.title%",
                "category": "IntelliGit",
                "icon": "$(git-commit)"
            },
            {
                "command": "intelligit.compareWithBranch",
                "title": "%command.compareWithBranch.title%",
                "category": "IntelliGit",
                "icon": "$(git-branch)"
            },
            {
                "command": "intelligit.commitFileCompareWithLocal",
                "title": "%command.commitFileCompareWithLocal.title%",
                "category": "IntelliGit",
                "icon": "$(diff)"
            },
            {
                "command": "intelligit.commitFileCherryPickChange",
                "title": "%command.commitFileCherryPickChange.title%",
                "category": "IntelliGit",
                "icon": "$(git-commit)"
            },
            {
                "command": "intelligit.commitFileRevertChange",
                "title": "%command.commitFileRevertChange.title%",
                "category": "IntelliGit",
                "icon": "$(discard)"
            },
            {
                "command": "intelligit.fileRefresh",
                "title": "%command.fileRefresh.title%",
                "category": "IntelliGit",
                "icon": "$(refresh)"
            },
            {
                "command": "intelligit.fileRefreshing",
                "title": "%command.fileRefreshing.title%",
                "category": "IntelliGit",
                "icon": "$(sync~spin)",
                "enablement": "false"
            },
            {
                "command": "intelligit.openMergeConflict",
                "title": "%command.openMergeConflict.title%",
                "category": "IntelliGit",
                "icon": "$(go-to-file)"
            },
            {
                "command": "intelligit.detectJetBrainsMergeTool",
                "title": "%command.detectJetBrainsMergeTool.title%",
                "category": "IntelliGit",
                "icon": "$(search)"
            },
            {
                "command": "intelligit.openMergeConflictInJetBrains",
                "title": "%command.openMergeConflictInJetBrains.title%",
                "category": "IntelliGit",
                "icon": "$(link-external)"
            },
            {
                "command": "intelligit.conflictAcceptYours",
                "title": "%command.conflictAcceptYours.title%",
                "category": "IntelliGit",
                "icon": "$(arrow-left)"
            },
            {
                "command": "intelligit.conflictAcceptTheirs",
                "title": "%command.conflictAcceptTheirs.title%",
                "category": "IntelliGit",
                "icon": "$(arrow-right)"
            },
            {
                "command": "intelligit.mergeConflictsRefresh",
                "title": "%command.mergeConflictsRefresh.title%",
                "category": "IntelliGit",
                "icon": "$(refresh)"
            },
            {
                "command": "intelligit.openConflictSession",
                "title": "%command.openConflictSession.title%",
                "category": "IntelliGit",
                "icon": "$(diff-multiple)"
            }
        ],
        "submenus": [
            {
                "id": "intelligit.editorContext",
                "label": "IntelliGit",
                "icon": "$(git-branch)"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "submenu": "intelligit.editorContext",
                    "when": "resourceScheme == file",
                    "group": "navigation@9"
                }
            ],
            "intelligit.editorContext": [
                {
                    "command": "intelligit.compareWithRevision",
                    "when": "resourceScheme == file",
                    "group": "1_compare@1"
                },
                {
                    "command": "intelligit.compareWithBranch",
                    "when": "resourceScheme == file",
                    "group": "1_compare@2"
                }
            ],
            "view/title": [
                {
                    "command": "intelligit.refresh",
                    "when": "view == intelligit.commitGraph",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.fileRefresh",
                    "when": "view == intelligit.commitPanel && !intelligit.commitPanel.refreshing",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.fileRefreshing",
                    "when": "view == intelligit.commitPanel && intelligit.commitPanel.refreshing",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.mergeConflictsRefresh",
                    "when": "view == intelligit.mergeConflicts",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.openConflictSession",
                    "when": "view == intelligit.mergeConflicts",
                    "group": "navigation@2"
                }
            ],
            "view/item/context": [
                {
                    "command": "intelligit.conflictAcceptYours",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "inline@1"
                },
                {
                    "command": "intelligit.conflictAcceptTheirs",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "inline@2"
                },
                {
                    "command": "intelligit.openMergeConflict",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "navigation@1"
                },
                {
                    "command": "intelligit.openMergeConflictInJetBrains",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "navigation@2"
                },
                {
                    "command": "intelligit.conflictAcceptYours",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "1_actions@1"
                },
                {
                    "command": "intelligit.conflictAcceptTheirs",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "1_actions@2"
                }
            ],
            "webview/context": [
                {
                    "command": "intelligit.fileRollback",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "1_actions@1"
                },
                {
                    "command": "intelligit.fileJumpToSource",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "1_actions@2"
                },
                {
                    "command": "intelligit.fileDelete",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "2_destructive@1"
                },
                {
                    "command": "intelligit.fileShelve",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "2_destructive@2"
                },
                {
                    "command": "intelligit.fileShowHistory",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "3_info@1"
                },
                {
                    "command": "intelligit.fileRefresh",
                    "when": "webviewId == 'intelligit.commitPanel' && !intelligit.commitPanel.refreshing",
                    "group": "3_info@2"
                },
                {
                    "command": "intelligit.commitFileCompareWithLocal",
                    "when": "(webviewId == 'intelligit.commitGraph' || webviewId == 'intelligit.commitFiles') && webviewSection == 'commitInfoFile'",
                    "group": "1_compare@1"
                },
                {
                    "command": "intelligit.commitFileCherryPickChange",
                    "when": "(webviewId == 'intelligit.commitGraph' || webviewId == 'intelligit.commitFiles') && webviewSection == 'commitInfoFile'",
                    "group": "2_apply@1"
                },
                {
                    "command": "intelligit.commitFileRevertChange",
                    "when": "(webviewId == 'intelligit.commitGraph' || webviewId == 'intelligit.commitFiles') && webviewSection == 'commitInfoFile'",
                    "group": "2_apply@2"
                }
            ]
        },
        "keybindings": [
            {
                "command": "intelligit.showGitLog",
                "key": "alt+9",
                "mac": "alt+9"
            }
        ],
        "configuration": {
            "title": "IntelliGit",
            "properties": {
                "intelligit.jetbrainsMergeTool.path": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "%config.jetbrainsMergeTool.path.description%"
                },
                "intelligit.jetbrainsMergeTool.preferExternal": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "%config.jetbrainsMergeTool.preferExternal.description%"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "bun scripts/build.js --production",
        "build": "bun scripts/build.js",
        "build:prod": "bun scripts/build.js --production",
        "watch": "bun scripts/watch.js",
        "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.js\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"scripts/**/*.js\"",
        "lint": "eslint src",
        "typecheck:ext": "tsc -p tsconfig.json --noEmit",
        "typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
        "typecheck": "bun run typecheck:ext && bun run typecheck:webview",
        "test": "bun vitest run",
        "test:coverage": "bun vitest run --coverage",
        "test:watch": "bun vitest",
        "package": "vsce package --no-dependencies",
        "publish": "vsce publish --no-dependencies"
    },
    "devDependencies": {
        "@chakra-ui/react": "^2.8.2",
        "@emotion/react": "^11.11.3",
        "@emotion/styled": "^11.11.0",
        "@eslint/js": "^10.0.1",
        "@types/node": "^20.11.0",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@types/vscode": "^1.96.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "@vitest/coverage-v8": "1.6.1",
        "@vscode/test-electron": "^2.3.9",
        "@vscode/vsce": "^2.22.0",
        "entities": "^6.0.1",
        "esbuild": "^0.20.0",
        "eslint": "^10.0.0",
        "eslint-plugin-react": "^7.37.5",
        "framer-motion": "^11.0.0",
        "globals": "^17.3.0",
        "jsdom": "^28.1.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-icons": "^5.5.0",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.55.0",
        "vitest": "^1.2.0"
    },
    "dependencies": {
        "jsonc-parser": "^3.3.1",
        "simple-git": "^3.32.3"
    }
}
